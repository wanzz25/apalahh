# ═══════════════════════════════════════════════════════
#  VPS Master Pro — Environment Variables
#  Copy file ini menjadi .env dan isi nilainya
# ═══════════════════════════════════════════════════════

# ── Supabase (WAJIB untuk cloud database) ─────────────────────
# Dapatkan dari: supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server port (untuk Pterodactyl) ──────────────────────────
PORT=3000

# ── Node environment ──────────────────────────────────────────
NODE_ENV=production
